# =============================================================================
# إعداد البيئة — انسخ هذا الملف إلى .env ثم عدّل القيم
#   نسخ (PowerShell من مجلد server):  Copy-Item .env.example .env
# لا ترفع ملف .env إلى Git (يحتوي أسراراً).
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB — اختر أحد الخيارين (أو ب فقط إذا احتجت عدة قواعد)
# -----------------------------------------------------------------------------

# [أ] اتصال واحد (الأكثر شيوعاً — Atlas أو محلي)
# استبدل USER و PASSWORD و اسم المجموعة بالقيم من لوحة MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/yasmeen?retryWrites=true&w=majority&appName=Cluster0

# محلي بدون Atlas (تطوير):
# MONGODB_URI=mongodb://127.0.0.1:27017/yasmeen

# [ب] عدة قواعد / عدة مفاتيح تطبيق (JSON في سطر واحد) — إن استخدمته، علّق السطر MONGODB_URI أعلاه
# DEFAULT_APP_KEY=yasmeen
 MONGODB_URI_MAP={"yasmeen":"mongodb+srv://USER:PASS@host/yasmeen?retryWrites=true&w=majority","client2":"mongodb+srv://USER:PASS@host/client2?retryWrites=true&w=majority"}

# -----------------------------------------------------------------------------
# مفتاح التطبيق — يجب أن يطابق window.API_APP_KEY في ملف api-config.js
# -----------------------------------------------------------------------------
DEFAULT_APP_KEY=yasmeen

# -----------------------------------------------------------------------------
# كلمة مرور صفحة إعداد قاعدة البيانات (db-config.html) — غيّرها في الإنتاج
# -----------------------------------------------------------------------------
ADMIN_CONFIG_PASSWORD=StrongAdminPassword_ChangeMe123

# -----------------------------------------------------------------------------
# المنفذ — محلياً غالباً 3000؛ على Render يُضبط تلقائياً ولا تحتاج تغييره
# -----------------------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------------------
# إنتاج / Render (اختياري)
# -----------------------------------------------------------------------------

# دومين أو أكثر للواجهة (CORS + يُحقَن للمتصفح كـ __PUBLIC_SITE_URL__) — مفصولة بفاصلة بدون مسافات زائدة
 PUBLIC_SITE_URL=https://www.example.com,https://example.com

# إن كانت الصفحات على دومين والـ API على رابط آخر — يُحقَن كـ window.API_BASE_URL
 PUBLIC_API_URL=https://your-service-name.onrender.com

# نفس وظيفة PUBLIC_SITE_URL (اسم بديل)
CLIENT_ORIGIN=https://www.example.com
